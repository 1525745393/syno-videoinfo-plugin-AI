# Syno VideoInfo 环境变量配置示例
# 复制为 .env 文件后修改

# 刮削器配置
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY=1.0
SCRAPER_MAX_CONCURRENT=5
SCRAPER_DOH_ENABLED=False

SCRAPER_DEFAULT_LANGUAGE=chs
SCRAPER_SCRAPE_TIMEOUT=60
SCRAPER_MAX_RESULTS=5

SCRAPER_CACHE_ENABLED=True
SCRAPER_CACHE_TTL=3600
SCRAPER_CACHE_DIR=.cache

SCRAPER_LOG_LEVEL=INFO
SCRAPER_LOG_FILE=scraper.log

SCRAPER_MIN_SUCCESS_RATE=0.5
SCRAPER_MIN_COMPLETENESS=0.6

# 禁用的刮削源（逗号分隔）
SCRAPER_DISABLED_SOURCES=

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=scraper.log

# 性能配置
PERFORMANCE_ENABLE_ASYNC=True
PERFORMANCE_POOL_MAXSIZE=20
PERFORMANCE_REQUEST_TIMEOUT=30

# 高级配置
ADVANCED_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
ADVANCED_VERIFY_SSL=True
ADVANCED_PROXY=
