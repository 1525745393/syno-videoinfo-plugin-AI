{
  "type": "movie",
  "site": "bangumi.tv",
  "doh_enabled": true,
  "steps": [
    {
      "http": {
        "url": "https://api.bgm.tv/search/subject/{title}?type=2&start=0&max_results=10",
        "method": "GET",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        },
        "result": "search_result"
      }
    },
    {
      "collect": {
        "source": "search_result",
        "into": {
          "bgm_ids": ["xp_texts", "//item[@type='subject']/@id"]
        }
      }
    },
    {
      "loop": {
        "source": "bgm_ids",
        "item": "bgm_id",
        "steps": [
          {
            "http": {
              "url": "https://api.bgm.tv/v0/subjects/{bgm_id}?responseGroup=large",
              "method": "GET",
              "headers": {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
              },
              "result": "detail_data"
            }
          },
          {
            "collect": {
              "source": "detail_data",
              "into": {
                "movie": {
                  "title": ["get", "name"],
                  "originaltitle": ["get", "name_cn"],
                  "original_available": ["get", "air_date"],
                  "summary": ["get", "summary"],
                  "genre": ["get", "tags"],
                  "extra": {
                    "[plugin_id]": {
                      "poster": ["get", "images/large"],
                      "rating": ["get", "rating/score"],
                      "bgmid": "{bgm_id}"
                    }
                  }
                }
              }
            }
          },
          {
            "retval": {
              "source": "movie"
            }
          }
        ]
      }
    }
  ]
}
