{
  "type": "movie",
  "site": "template-site.com",
  "doh_enabled": false,
  "lang": ["chs"],
  "config": {
    "cookie": {
      "icon": "key",
      "name": "Cookie"
    }
  },
  "steps": [
    {
      "http": {
        "url": "https://example.com/search?q={title}",
        "method": "GET",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
          "Cookie": "{cookie}"
        },
        "timeout": 15,
        "result": "search_result"
      }
    },
    {
      "collect": {
        "source": "search_result",
        "into": {
          "urls": ["re_matches", "/movie/([a-z0-9]+)"]
        }
      }
    },
    {
      "loop": {
        "source": "urls",
        "item": "url",
        "iferr": "continue",
        "steps": [
          {
            "http": {
              "url": "https://example.com/movie/{url}",
              "headers": {
                "Cookie": "{cookie}"
              },
              "timeout": 15,
              "result": "detail"
            }
          },
          {
            "collect": {
              "source": "detail",
              "into": {
                "movie": {
                  "title": ["xp_text", "//h1"],
                  "original_available": ["re_match", "发布时间：(\\d{4}-\\d{2}-\\d{2})"],
                  "summary": ["xp_text", "//div[@class='description']"],
                  "genre": ["xp_texts", "//div[@class='genres']/a"],
                  "actor": ["xp_texts", "//div[@class='actors']/a"],
                  "director": ["xp_texts", "//div[@class='directors']/a"],
                  "extra": {
                    "[plugin_id]": {
                      "poster": ["xp_attr_src", "//img[@class='poster']/@src"],
                      "rating": ["re_match", "评分：(\\d+\\.\\d)"]
                    }
                  }
                }
              }
            }
          },
          {
            "retval": {
              "source": "movie"
            }
          }
        ]
      }
    }
  ]
}
