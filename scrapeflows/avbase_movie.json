{
  "type": "movie",
  "site": "avbase.net",
  "doh_enabled": false,
  "lang": ["ja"],
  "config": {},
  "steps": [
    {"http": {"url": "https://www.avbase.net/works?q={title}", "method": "GET", "result": "search_result"}},
    {"collect": {"source": "search_result", "into": {"detail_url": ["xp_attr", "//a[starts-with(@href, '/works/') and not(contains(@href, '/date'))][1]/@href"]}}},
    {"http": {"url": "https://www.avbase.net{detail_url}", "method": "GET", "result": "detail_content"}},
    {"collect": {"source": "detail_content", "into": {"next_data": ["xp_text", "//script[@id='__NEXT_DATA__']/text()"]}}},
    {"transform": {"expression": "import json; data = json.loads(next_data); work = data.get('props', {}).get('pageProps', {}).get('work', {})"}},
    {"collect": {"source": "detail_content", "into": {"number": ["json_path", "work.work_id"], "title": ["json_path", "work.title"], "outline": ["json_path", "work.note"], "actors": ["json_path", "work.casts"], "thumb": ["json_path", "work.products[0].image_url"], "release": ["json_path", "work.products[0].date"], "studio": ["json_path", "work.products[0].maker.name"], "publisher": ["json_path", "work.products[0].label.name"], "series": ["json_path", "work.products[0].series.name"], "genres": ["json_path", "work.genres"], "tags": ["json_path", "work.tags"]}}},
    {"transform": {"expression": "actor_list = [a.get('actor', {}).get('name', '') for a in actors if isinstance(a, dict) and a.get('actor')] if actors else []"}},
    {"transform": {"expression": "tag_list = [g.get('name', '') for g in genres if isinstance(g, dict) and g.get('name')] + [t.get('name', '') for t in tags if isinstance(t, dict) and t.get('name')] if genres or tags else []"}},
    {"transform": {"expression": "release = re.findall(r'\\d{4}-\\d{2}-\\d{2}', release)[0] if release else ''"}},
    {"transform": {"expression": "year = release[:4] if release else ''"}},
    {"transform": {"expression": "thumb = 'https://www.avbase.net' + thumb if thumb and not thumb.startswith('http') else thumb"}},
    {"retval": {"title": "{title}", "originaltitle": "{title}", "number": "{number}", "actors": "{actor_list}", "outline": "{outline}", "tags": "{tag_list}", "release": "{release}", "year": "{year}", "series": "{series}", "studio": "{studio}", "publisher": "{publisher if publisher else studio}", "thumb": "{thumb}", "poster": "{thumb.replace('pl.jpg', 'ps.jpg') if thumb else ''}", "mosaic": "有码", "external_id": "https://www.avbase.net{detail_url}"}}
  ]
}