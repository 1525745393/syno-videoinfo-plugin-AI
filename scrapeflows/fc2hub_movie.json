{
  "type": "movie",
  "site": "javten.com",
  "doh_enabled": true,
  "steps": [
    {
      "http": {
        "url": "https://javten.com/search?kw={title}",
        "method": "GET",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        },
        "result": "search_result"
      }
    },
    {
      "collect": {
        "source": "search_result",
        "into": {
          "detail_urls": ["re_matches", "/fc2ppv/\\d+"]
        }
      }
    },
    {
      "loop": {
        "source": "detail_urls",
        "item": "detail_url",
        "steps": [
          {
            "http": {
              "url": "https://javten.com{detail_url}",
              "method": "GET",
              "headers": {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
              },
              "result": "detail_page"
            }
          },
          {
            "collect": {
              "source": "detail_page",
              "into": {
                "movie": {
                  "title": ["xp_text", "//h1/text()[2]"],
                  "original_available": "",
                  "summary": ["xp_text", "//div[@class='col des']"],
                  "genre": ["xp_texts", "//p[@class='card-text']/a[contains(@href,'/tag/')]"],
                  "extra": {
                    "[plugin_id]": {
                      "poster": ["xp_attr_href", "//a[@data-fancybox='gallery']/@href"],
                      "studio": ["xp_text", "//div[@class='col-8']"],
                      "series": "FC2系列",
                      "number": ["re_match", "FC2-?(\\d+)"]
                    }
                  }
                }
              }
            }
          },
          {
            "retval": {
              "source": "movie"
            }
          }
        ]
      }
    }
  ]
}
