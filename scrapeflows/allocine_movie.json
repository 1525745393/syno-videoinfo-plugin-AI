{
  "type": "movie",
  "site": "allocine.fr",
  "doh_enabled": true,
  "lang": ["fr", "en"],
  "steps": [
    {
      "http": {
        "url": "https://www.allocine.fr/recherche/?q={title}",
        "method": "GET",
        "headers": {
          "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
          "Accept-Language": "fr-FR,fr;q=0.9,en;q=0.8"
        },
        "timeout": 15,
        "result": "search_result"
      }
    },
    {
      "collect": {
        "source": "search_result",
        "into": {
          "movie_links": ["re_matches", "href=\"(/film/[^\"]+)\""]
        }
      }
    },
    {
      "loop": {
        "source": "movie_links",
        "item": "movie_link",
        "iferr": "continue",
        "steps": [
          {
            "http": {
              "url": "https://www.allocine.fr{movie_link}",
              "method": "GET",
              "headers": {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
              },
              "timeout": 15,
              "result": "movie_detail"
            }
          },
          {
            "collect": {
              "source": "movie_detail",
              "into": {
                "movie": {
                  "title": ["re_match", "titlebar[^>]+>([^<]+)<"],
                  "originaltitle": ["re_match", "originaltitle[^>]+>([^<]+)<"],
                  "original_available": ["re_match", "date[^>]+>([0-9]{2}/[0-9]{2}/[0-9]{4})"],
                  "summary": ["re_match", "synopsis[^>]*>([^<]+)<"],
                  "genre": ["re_matches", "genre[^>]+>([^<]+)<"],
                  "actor": ["re_matches", "actor[^>]+>([^<]+)<"],
                  "director": ["re_matches", "director[^>]+>([^<]+)<"],
                  "extra": {
                    "[plugin_id]": {
                      "poster": ["re_match", "poster[^>]*src=\"([^\"]+)\""],
                      "rating": ["re_match", "starring-average[^>]+>([0-9.]+)"],
                      "press_rating": ["re_match", "press[^>]+>([0-9.]+)"],
                      "spectator_rating": ["re_match", "spectator[^>]+>([0-9.]+)"]
                    }
                  }
                }
              }
            }
          },
          {
            "retval": {
              "source": "movie"
            }
          }
        ]
      }
    }
  ]
}
