{
  "type": "movie",
  "site": "themoviedb.org",
  "doh_enabled": true,
  "config": {
    "apikey": {
      "icon": "key",
      "name": "API Key"
    }
  },
  "steps": [
    {
      "retval": {
        "ifempty": "apikey"
      }
    },
    {
      "doh": {
        "host": "api.tmdb.org"
      }
    },
    {
      "http": {
        "url": "https://api.tmdb.org/3/search/movie?api_key={apikey}&language={lang}&query={title}&year={year}&page=1",
        "method": "GET",
        "headers": {
          "Accept": "application/json"
        },
        "timeout": 20,
        "result": "metadata"
      }
    },
    {
      "collect": {
        "source": "metadata",
        "into": {
          "movie_ids": ["get", "results"]
        }
      }
    },
    {
      "loop": {
        "source": "movie_ids",
        "item": "movie_item",
        "steps": [
          {
            "http": {
              "url": "https://api.tmdb.org/3/movie/{$parent[movie_item][id]}?api_key={$parent[apikey]}&language={$parent[lang]}&append_to_response=credits,release_dates",
              "method": "GET",
              "headers": {
                "Accept": "application/json"
              },
              "timeout": 20,
              "result": "subject"
            }
          },
          {
            "collect": {
              "source": "subject",
              "into": {
                "movie": {
                  "title": ["get", "title"],
                  "tagline": ["get", "tagline"],
                  "original_available": ["get", "release_date"],
                  "summary": ["get", "overview"],
                  "certificate": ["re_match", "certification\":\"([^\"]*)\""],
                  "genre": ["get", "genres"],
                  "actor": ["get", "credits/cast"],
                  "writer": ["re_matches", "\"name\":\"([^\"]*)\"[^{}]*?\"department\":\"Writing\""],
                  "director": ["re_matches", "\"name\":\"([^\"]*)\"[^{}]*?\"department\":\"Directing\""],
                  "extra": {
                    "[plugin_id]": {
                      "poster": ["get", "poster_path"],
                      "backdrop": ["get", "backdrop_path"],
                      "rating": ["get", "vote_average"],
                      "reference": {
                        "themoviedb": ["get", "id"],
                        "imdb": ["get", "imdb_id"]
                      },
                      "collection_id": ["get", "belongs_to_collection/id"]
                    }
                  }
                },
                "rating_value": ["get", "vote_average"]
              }
            }
          },
          {
            "collect": {
              "source": "rating_value",
              "into": {
                "movie": {
                  "extra": {
                    "[plugin_id]": {
                      "rating": {
                        "[plugin_id]": ["re_match", "(\\d+\\.\\d)"]
                      }
                    }
                  }
                }
              }
            }
          },
          {
            "retval": {
              "source": "movie"
            }
          }
        ]
      }
    }
  ]
}