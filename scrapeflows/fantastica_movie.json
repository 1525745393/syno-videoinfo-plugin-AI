{
  "type": "movie",
  "site": "fantastica-vr.com",
  "doh_enabled": false,
  "lang": ["ja"],
  "config": {},
  "steps": [
    {
      "http": {
        "url": "http://fantastica-vr.com/items/search?q={title}",
        "method": "GET",
        "result": "search_result"
      }
    },
    {
      "collect": {
        "source": "search_result",
        "into": {
          "search_links": ["xp_attr_all", "//section[@class=\"item_search item_list clearfix\"]/div/ul/li/a/@href"],
          "search_posters": ["xp_attr_all", "//section[@class=\"item_search item_list clearfix\"]/div/ul/li/a/img/@src"]
        }
      }
    },
    {
      "loop": {
        "source": "search_links",
        "item": "link",
        "index": "idx",
        "steps": [
          {
            "if": {
              "condition": "{title.lower().replace('-', '') in link.lower().replace('-', '')}",
              "then": [
                {
                  "collect": {
                    "source": "search_posters",
                    "into": {
                      "search_poster": "{search_posters[idx]}"
                    }
                  }
                },
                {
                  "http": {
                    "url": "http://fantastica-vr.com{link}",
                    "method": "GET",
                    "result": "detail_content"
                  }
                },
                {
                  "collect": {
                    "source": "detail_content",
                    "into": {
                      "title": ["xp_text", "//div[@class=\"title-area\"]/h2/text()"],
                      "originaltitle": ["xp_text", "//div[@class=\"title-area\"]/h2/text()"],
                      "actors": ["xp_text_all", "//th[contains(text(),'出演者')]/following-sibling::td//text()"],
                      "outline": ["xp_text", "string(//p[@class=\"explain\"])"],
                      "originalplot": ["xp_text", "string(//p[@class=\"explain\"])"],
                      "release": ["xp_text", "//th[contains(text(),'発売日')]/following-sibling::td//text()"],
                      "runtime": ["xp_text", "//th[contains(text(),'収録時間')]/following-sibling::td//text()"],
                      "series": ["xp_text", "//th[contains(text(),'シリーズ')]/following-sibling::td//text()"],
                      "tags": ["xp_text_all", "//th[contains(text(),'ジャンル')]/following-sibling::td/a/text()"],
                      "thumb": ["xp_attr", "//div[@class=\"vr_wrapper clearfix\"]/div[@class=\"img\"]/img/@src"],
                      "extrafanart": ["xp_attr_all", "//div[@class=\"vr_images clearfix\"]/div[@class=\"vr_image\"]/a/@href"],
                      "mosaic": "有码"
                    }
                  }
                },
                {
                  "break": {}
                }
              ]
            }
          }
        ]
      }
    },
    {
      "retval": {
        "title": "{title}",
        "originaltitle": "{originaltitle}",
        "actors": "{actors}",
        "outline": "{outline}",
        "originalplot": "{originalplot}",
        "release": "{release.replace('年', '-').replace('月', '-').replace('日', '')}",
        "year": "{re.findall('\\d{4}', release.replace('年', '-').replace('月', '-').replace('日', ''))[0] if release and len(re.findall('\\d{4}', release.replace('年', '-').replace('月', '-').replace('日', ''))) > 0 else ''}",
        "runtime": "{runtime.replace('分', '')}",
        "series": "{series}",
        "studio": "ファンタスティカ",
        "publisher": "ファンタスティカ",
        "tags": "{tags}",
        "thumb": "{thumb if thumb != 'https://assets.fantastica-vr.com/assets/common/img/dummy_large_white.jpg' else ''}",
        "poster": "{search_poster if search_poster != 'https://assets.fantastica-vr.com/assets/common/img/dummy_white.jpg' else (extrafanart[0] if len(extrafanart) > 0 else '')}",
        "extrafanart": "{extrafanart}",
        "trailer": "",
        "mosaic": "{mosaic}"
      }
    }
  ]
}
