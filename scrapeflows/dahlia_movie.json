{
  "type": "movie",
  "site": "dahlia-av.jp",
  "doh_enabled": false,
  "lang": ["ja"],
  "config": {},
  "steps": [
    {"http": {"url": "https://dahlia-av.jp/works/{title.lower().replace('-', '')}/", "method": "GET", "result": "detail_content"}},
    {"collect": {"source": "detail_content", "into": {"title": ["xp_text", "//h1/text()"]}}},
    {"collect": {"source": "detail_content", "into": {"actor": ["xp_text", "//div[@class='box_works01_list clearfix']//span[text()='出演女優']/following-sibling::p[1]/text()"]}}},
    {"collect": {"source": "detail_content", "into": {"outline": ["xp_text", "//div[@class='box_works01_text']/p/text()"]}}},
    {"collect": {"source": "detail_content", "into": {"runtime": ["xp_text", "//span[contains(text(), '収録時間')]/following-sibling::*//text()"]}}},
    {"transform": {"expression": "runtime = re.findall(r'\\d+', runtime)[0] if runtime else ''"}},
    {"collect": {"source": "detail_content", "into": {"series": ["xp_text", "//span[contains(text(), '系列')]/following-sibling::*//text()"]}}},
    {"collect": {"source": "detail_content", "into": {"release": ["xp_text", "//div[@class='view_timer']//span[text()='配信開始日']/following-sibling::p[1]/text()"]}}},
    {"transform": {"expression": "release = release.replace('/', '-') if release else ''"}},
    {"collect": {"source": "detail_content", "into": {"cover_url": ["xp_attr", "//a[@class='pop_sample']/img/@src"]}}},
    {"transform": {"expression": "cover_url = cover_url.replace('?output-quality=60', '') if cover_url else ''"}},
    {"collect": {"source": "detail_content", "into": {"extrafanart": ["xp_attr", "//a[@class='pop_img']/@href"]}}},
    {"collect": {"source": "detail_content", "into": {"trailer": ["xp_attr", "//a[@class='pop_sample']/@href"]}}},
    {"retval": {"title": "{title}", "number": "{title}", "actors": ["split_csv", "{actor}"], "outline": "{outline}", "tags": [], "release": "{release}", "year": "{release[:4] if release else ''}", "runtime": "{runtime}", "series": "{series}", "studio": "DAHLIA", "publisher": "DAHLIA", "thumb": "{cover_url}", "poster": "{cover_url}", "extrafanart": "{extrafanart}", "trailer": "{trailer}", "mosaic": "有码"}}
  ]
}